# Copy to client/.env and fill in for production deployments.
# In dev, the Vite proxy in vite.config.js forwards /api to http://localhost:5000,
# so VITE_API_URL is optional locally.

# Backend base URL (no trailing slash, no /api suffix — that's appended automatically).
# Required when frontend and backend are served from different origins.
VITE_API_URL=http://localhost:5000

# Razorpay public key. Optional — the useRazorpay hook falls back to whatever
# key_id the server returns with the order. Set this to skip a tiny round trip.
VITE_RAZORPAY_KEY_ID=

# Firebase web config — required for "Continue with Google" sign-in.
# Get these from Firebase Console → Project Settings → General → Your apps → Web app.
# Without these the Google button shows a friendly "not configured" toast.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
